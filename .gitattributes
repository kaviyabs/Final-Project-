# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.css text eol=lf
*.md text eol=lf
*.html text eol=lf

# Configuration files
.gitignore text eol=lf
.gitattributes text eol=lf
eslint.config.js text eol=lf
postcss.config.js text eol=lf
vite.config.ts text eol=lf
tailwind.config.ts text eol=lf
tsconfig.json text eol=lf
tsconfig.app.json text eol=lf
tsconfig.node.json text eol=lf
components.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
